{
  "name": "@voxgig-sdk/ec2-shop",
  "version": "0.0.1",
  "description": "Unofficial generated TypeScript SDK for the EC2 Shop public API. Not affiliated with or endorsed by the upstream API provider.",
  "keywords": [
    "voxgig",
    "sdk",
    "generated-sdk",
    "openapi",
    "api-client",
    "ec2-shop"
  ],
  "homepage": "https://github.com/voxgig-sdk/ec2-shop-sdk#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/voxgig-sdk/ec2-shop-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/voxgig-sdk/ec2-shop-sdk/issues"
  },
  "main": "dist/Ec2ShopSDK.js",
  "type": "commonjs",
  "types": "dist/Ec2ShopSDK.d.ts",
  "scripts": {
    "test": "node --enable-source-maps --test-concurrency=1 --test 'dist-test/**/*.test.js'",
    "test-some": "node --enable-source-maps --experimental-test-isolation=none --test-name-pattern=\"$TEST_PATTERN\" --test 'dist-test/**/*.test.js'",
    "test-utility": "node --enable-source-maps --test test/utility/*.test.ts",
    "watch": "tsc --build src test -w",
    "build": "tsc --build src test",
    "clean": "rm -rf node_modules yarn.lock package-lock.json",
    "reset": "npm run clean && npm i && npm run build && npm test"
  },
  "author": {
    "name": "Voxgig",
    "url": "https://voxgig.com"
  },
  "license": "MIT",
  "dependencies": {},
  "peerDependencies": {},
  "devDependencies": {
    "@types/node": "^25.6.0",
    "dotenv": "^17.4.2",
    "typescript": "^5.9.3"
  }
}